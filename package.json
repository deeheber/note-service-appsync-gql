{
  "name": "note-service-next-generation",
  "version": "2.0.0",
  "bin": {
    "note-service": "bin/note-service.js"
  },
  "scripts": {
    "build": "tsc",
    "buildresolvers": "node build.mjs",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "pretest": "npm run build",
    "test": "jest",
    "cdk": "cdk",
    "predeploy": "npm run buildresolvers",
    "deploy": "npm run cdk deploy -a NoteServiceStack",
    "destroy": "npm run cdk destroy -a NoteServiceStack",
    "synth": "npm run build && npm run cdk synth > template.yaml"
  },
  "peerDependencies": {
    "aws-cdk-lib": "2.234.1",
    "constructs": "10.4.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.6",
    "aws-cdk": "2.1100.3",
    "aws-cdk-lib": "2.234.1",
    "constructs": "10.4.4",
    "esbuild": "^0.27.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-appsync/utils": "^2.0.3",
    "glob": "^13.0.0"
  }
}
